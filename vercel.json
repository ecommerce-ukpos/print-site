{
  "version": 2,
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/jobs",   "dest": "/api/jobs"   },
    { "src": "/api/job",    "dest": "/api/job"    },
    { "src": "/api/assess", "dest": "/api/assess" },
    { "src": "/api/upload", "dest": "/api/upload" },
    { "src": "/api/file",   "dest": "/api/file"   },
    { "src": "/api/sku",    "dest": "/api/sku"    },
    { "src": "/(.*)",       "dest": "/public/$1"  }
  ]
}
